{
  "expo": {
    "name": "payallapp",
    "slug": "payallapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "payallapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./src/assets/images/notification-icon.png",
      "color": "#000000"
    },
    "ios": {
      "icon": "./assets/ios-app-icon-1024.png",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "bundleIdentifier": "com.payallapp",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show your position on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to show your position on the map.",
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "android": {
      "icon": "./src/assets/images/icon-android.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.payallapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-bootsplash",
        {
          "background": "#000000",
          "logo": "./src/assets/images/logo.png",
          "logoWidth": 192
        }
      ],
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
